# Neon Postgres
DATABASE_URL=postgresql://...

# Better Auth
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000

# Firebase Admin SDK (server-side FCM dispatch)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
# Contains newlines — wrap in quotes in Vercel dashboard.
# In code: process.env.FIREBASE_PRIVATE_KEY!.replace(/\\n/g, "\n")
FIREBASE_PRIVATE_KEY=

# Firebase Client SDK (FCM web push — public)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_VAPID_KEY=

# Vercel Blob
BLOB_READ_WRITE_TOKEN=

# Vercel Cron (protects /api/jobs/*)
CRON_SECRET=

# Resend (transactional email)
RESEND_API_KEY=
EMAIL_FROM_ADDRESS=no-reply@mail.akivot.com

# App URL
NEXT_PUBLIC_APP_URL=http://localhost:3000
